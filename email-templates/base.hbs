<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <style>
      body { font-family: 'Arial', sans-serif; margin: 0; padding: 0;
      line-height: 1.6; color: #333; background-color: #f5f5f5; position:
      relative; line-height: 100%; } .container { max-width: 750px; margin: 0
      auto; } .header {padding: 60px 30px; display: flex; justify-content:
      space-between; align-items: center; background-image:
      url("/images/template-header.png"); background-position: contain;
      background-size: cover; background-position: center; background-repeat:
      no-repeat; } .logo { height: 40px; } .receipt-icon { height: 60px; }
      .wave-divider { height: 40px; background-color: #B11116; position:
      relative; overflow: hidden; } .wave-divider::after { content: ""; display:
      block; position: absolute; border-radius: 100%; width: 100%; height:
      300px; background-color: #f5f5f5; right: -25%; top: 20px; }
      .wave-divider::before { content: ""; display: block; position: absolute;
      border-radius: 100%; width: 100%; height: 300px; background-color:
      #f5f5f5; left: -25%; top: 20px; } .content { padding: 0px 40px 0px 40px;
      margin-top: -40px; z-index: 10} h1, h2, h3 { color: #8B0000; margin-top:
      0; line-height: 100%; font-weight: 500 !important; } p { line-height: 1.0;
      margin: 0px } .btn { display: inline-block; background-color: #8B0000;
      color: white; text-decoration: none; padding: 10px 20px; border-radius:
      4px; font-weight: bold; } .highlight-box { background-color: #FFF0F0;
      border-radius: 8px; padding: 20px; margin: 20px 0; } .feature {
      text-align: center; margin-bottom: 20px; } .feature-icon {
      background-color: #8B0000; color: white; width: 50px; height: 50px;
      border-radius: 50%; display: flex; align-items: center; justify-content:
      center; margin: 0 auto 10px; font-size: 24px; } .signature { margin-top:
      30px; } .social-icons { text-align: center; margin: 20px 0; display: flex;
      gap: 12px } .social-icon { display: inline-block; width: 30px; height:
      30px; background-color: #f5f5f5; border-radius: 50%; margin: 0 5px;
      text-align: center; line-height: 30px; border:1px solid #333333; display:
      flex; justify-content: center; align-items: center; } .footer-text {
      font-size: 12px; color: #666; text-align: center; padding: 0 30px 20px; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <img
          src="https://example.com/idcertify-logo.png"
          alt="ID Certify"
          class="logo"
        />
        {{#if showReceiptIcon}}
          <img
            src="https://example.com/receipt-icon.png"
            alt="Receipt"
            class="receipt-icon"
          />
        {{/if}}
      </div>

      {{! <div class="wave-divider"></div> }}

      <div class="content">
        {{{body}}}
      </div>
      <div style="display: flex; justify-content: center;">

        <div class="social-icons">
          <a href="https://facebook.com/IDCertify" class="social-icon"><svg
              xmlns="http://www.w3.org/2000/svg"
              width="13"
              height="13"
              fill="black"
              viewBox="0 0 24 24"
            >
              <path
                d="M13 8h3V5h-3c-1.66 0-3 1.34-3 3v2H7v3h3v8h3v-8h2.5l.5-3H13V8z"
              />
            </svg>
          </a>
          <a href="https://twitter.com/IDCertify" class="social-icon"><svg
              xmlns="http://www.w3.org/2000/svg"
              width="13"
              height="13"
              fill="black"
              viewBox="0 0 24 24"
            >
              <path
                d="M23 3a10.9 10.9 0 0 1-3.14 1.53A4.48 4.48 0 0 0 22.4 1.64a9.07 9.07 0 0 1-2.88 1.1A4.52 4.52 0 0 0 16.11 0c-2.5 0-4.51 2.01-4.51 4.5 0 .35.04.7.12 1.03C7.69 5.41 4.07 3.61 1.64.9a4.48 4.48 0 0 0-.61 2.27c0 1.57.8 2.96 2.01 3.77A4.48 4.48 0 0 1 .96 6v.06a4.52 4.52 0 0 0 3.63 4.43 4.52 4.52 0 0 1-2.04.08 4.52 4.52 0 0 0 4.21 3.13A9.05 9.05 0 0 1 0 19.54 12.8 12.8 0 0 0 6.92 21c8.3 0 12.84-6.87 12.84-12.83 0-.2 0-.39-.01-.58A9.22 9.22 0 0 0 23 3z"
              />
            </svg>
          </a>
          <a href="https://instagram.com/IDCertify" class="social-icon"><svg
              xmlns="http://www.w3.org/2000/svg"
              width="13"
              height="13"
              fill="black"
              viewBox="0 0 24 24"
            >
              <path
                d="M7 2C4.24 2 2 4.24 2 7v10c0 2.76 2.24 5 5 5h10c2.76 0 5-2.24 5-5V7c0-2.76-2.24-5-5-5H7zm10 2c1.66 0 3 1.34 3 3v10c0 1.66-1.34 3-3 3H7c-1.66 0-3-1.34-3-3V7c0-1.66 1.34-3 3-3h10zM12 7a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6zm4.5-2a1 1 0 100 2 1 1 0 000-2z"
              />
            </svg>
          </a>
          <a href="https://youtube.com/IDCertify" class="social-icon"><svg
              xmlns="http://www.w3.org/2000/svg"
              width="13"
              height="13"
              viewBox="0 0 24 24"
            >
              <rect width="24" height="24" rx="4" fill="black" />
              <polygon points="10,8.5 16,12 10,15.5" fill="white" />
            </svg>

          </a>
        </div>
      </div>
      <div class="footer-text" style="display: flex; justify-content: center">
        <div style="max-width: 550px">
          <p style="margin-bottom: 12px">&copy;
            {{year}}
            Finclusion Technologies Ltd. All rights reserved.</p>
          <p>If you would like to find out more about which Finclusion
            Technologies entity you receive services from, please reach out to
            us via the in-app chat in the Finclusion.ai</p>
        </div>
      </div>
    </div>
  </body>
</html>