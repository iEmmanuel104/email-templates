<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    body {
      font-family: 'Arial', sans-serif;
      margin: 0;
      padding: 0;
      line-height: 1.6;
      color: #333;
      background-color: #f5f5f5;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background-color: #ffffff;
    }
    .header {
      background-color: #B11116;
      padding: 20px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo {
      height: 40px;
    }
    .receipt-icon {
      height: 60px;
    }
    .wave-divider {
      height: 40px;
      background-color: #B11116;
      position: relative;
      overflow: hidden;
    }
    .wave-divider::after {
      content: "";
      display: block;
      position: absolute;
      border-radius: 100%;
      width: 100%;
      height: 300px;
      background-color: #f5f5f5;
      right: -25%;
      top: 20px;
    }
    .wave-divider::before {
      content: "";
      display: block;
      position: absolute;
      border-radius: 100%;
      width: 100%;
      height: 300px;
      background-color: #f5f5f5;
      left: -25%;
      top: 20px;
      z-index: 1;
    }
    .content {
      padding: 20px 30px;
      background-color: #f5f5f5;
    }
    h1, h2, h3 {
      color: #8B0000;
      margin-top: 0;
    }
    p {
      margin-bottom: 16px;
    }
    .btn {
      display: inline-block;
      background-color: #8B0000;
      color: white;
      text-decoration: none;
      padding: 10px 20px;
      border-radius: 4px;
      font-weight: bold;
    }
    .highlight-box {
      background-color: #FFF0F0;
      border-radius: 8px;
      padding: 20px;
      margin: 20px 0;
    }
    .feature {
      text-align: center;
      margin-bottom: 20px;
    }
    .feature-icon {
      background-color: #8B0000;
      color: white;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 10px;
      font-size: 24px;
    }
    .signature {
      margin-top: 30px;
    }
    .social-icons {
      text-align: center;
      margin: 20px 0;
    }
    .social-icon {
      display: inline-block;
      width: 30px;
      height: 30px;
      background-color: #f5f5f5;
      border-radius: 50%;
      margin: 0 5px;
      text-align: center;
      line-height: 30px;
    }
    .footer-text {
      font-size: 12px;
      color: #666;
      text-align: center;
      padding: 0 30px 20px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <img src="https://example.com/idcertify-logo.png" alt="ID Certify" class="logo">
      {{#if showReceiptIcon}}
      <img src="https://example.com/receipt-icon.png" alt="Receipt" class="receipt-icon">
      {{/if}}
    </div>
    
    <div class="wave-divider"></div>
    
    <div class="content">
      {{{body}}}
    </div>
    
    <div class="social-icons">
      <a href="https://facebook.com/IDCertify" class="social-icon">f</a>
      <a href="https://twitter.com/IDCertify" class="social-icon">t</a>
      <a href="https://instagram.com/IDCertify" class="social-icon">i</a>
      <a href="https://youtube.com/IDCertify" class="social-icon">y</a>
    </div>

    <div class="footer-text">
      <p>&copy; {{year}} Finclusion Technologies Ltd. All rights reserved.</p>
      <p>If you would like to find out more about which Finclusion Technologies entity you receive services from, please reach out to us via the in-app chat in the Finclusion.ai</p>
    </div>
  </div>
</body>
</html>